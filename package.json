{
  "name": "vastai-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Vast.ai GPU Cloud - stdio & SSE/HTTP dual transport",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "vastai-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "vastai",
    "gpu",
    "cloud",
    "ai",
    "model-context-protocol"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc && node -e \"import('fs').then(fs=>{const f='dist/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);})\"",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.18.0",
    "dotenv": "^16.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0"
  }
}
